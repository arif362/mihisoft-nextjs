# Mihisoft Technologies - Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit actual .env files with real values!

# ===================
# Site Configuration
# ===================
NEXT_PUBLIC_SITE_URL=https://mihisoft.com

# ===================
# Analytics (Optional)
# ===================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ===================
# Contact Form (if adding backend)
# ===================
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# CONTACT_EMAIL=info@mihisoft.com

# ===================
# AWS (for CI/CD deployment only)
# ===================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=mihisoft-website
# CLOUDFRONT_DISTRIBUTION_ID=

# ===================
# Google Search Console (Optional)
# ===================
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
