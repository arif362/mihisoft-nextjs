# Mihisoft Technologies - Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit actual .env files with real values!

# ===================
# Site Configuration
# ===================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===================
# Analytics (Optional)
# ===================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ===================
# Contact Form (Formspree - S3 Friendly)
# ===================
# Set this to your Formspree endpoint, e.g. https://formspree.io/f/xxxxabcd
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=

# ===================
# AWS (for CI/CD deployment only)
# ===================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=mihisoft-website
# CLOUDFRONT_DISTRIBUTION_ID=

# ===================
# Google Search Console (Optional)
# ===================
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
