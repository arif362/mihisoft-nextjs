# Mihisoft Technologies - Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit actual .env files with real values!

# ===================
# Site Configuration
# ===================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===================
# Analytics (Optional)
# ===================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ===================
# Contact Form (SMTP Email)
# ===================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=xxxxx@gmail.com
SMTP_PASSWORD=your-gmail-app-password
CONTACT_TO_EMAILS=x@mihisoft.com,y@mihisoft.com
# Backward-compatible single receiver (optional)
# CONTACT_TO_EMAIL=info@mihisoft.com
# Optional, defaults to SMTP_USER
# CONTACT_FROM_EMAIL=no-reply@mihisoft.com

# Contact form security controls
CONTACT_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=600000
CONTACT_MAX_NAME_LENGTH=80
CONTACT_MAX_PHONE_LENGTH=30
CONTACT_MAX_SUBJECT_LENGTH=140
CONTACT_MAX_MESSAGE_LENGTH=5000

# ===================
# AWS (for CI/CD deployment only)
# ===================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=mihisoft-website
# CLOUDFRONT_DISTRIBUTION_ID=

# ===================
# Google Search Console (Optional)
# ===================
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
